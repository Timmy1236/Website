{
  "name": "Timmy's Digital Dumpster",
  "version": "1.0.0",
  "description": "Una simple página web que contendrá información básica de mí y de todos los proyectos que haré en algún futuro.",
  "main": "index.js",
  "scripts": {
    "start": "cd public && python -m http.server 8000",
    "style": "npx stylelint \"**/*.css\"",
    "build": "npx @11ty/eleventy",
    "build:watch": "npx @11ty/eleventy --watch",
    "bundle": "esbuild public/javascript/core/app-init.js --bundle --minify --outfile=public/dist/app.js && esbuild public/javascript/pages/11ty/11ty-init.js --bundle --minify --outfile=public/dist/11ty.js",
    "bundle:watch": "esbuild public/javascript/core/app-init.js --bundle --minify --watch --outfile=public/dist/app.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Timmy1236/Website.git"
  },
  "keywords": [
    "website",
    "web"
  ],
  "author": "Timmy1236 (https://timmy.nekoweb.org/)",
  "licenses": [
    {
      "type": "CC BY-NC-SA 4.0",
      "url": "https://github.com/Timmy1236/Website/blob/main/LICENSE"
    }
  ],
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Timmy1236/Website/issues"
  },
  "homepage": "https://github.com/Timmy1236/Website#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "esbuild": "^0.27.4",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "dependencies": {
    "mithril": "^2.3.8",
    "swup": "^4.8.3"
  }
}