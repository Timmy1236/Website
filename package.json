{
  "name": "timmys-digital-dumpster",
  "version": "1.0.0",
  "description": "Una simple página web que contendrá información básica de mí y de todos los proyectos que haré en algún futuro.",
  "scripts": {
    "dev": "concurrently \"npm:eleventy:watch\" \"npm:js:watch\" \"npm:css:watch\" \"npm:css:pages:watch\"",
    "build": "npm run eleventy && npm run js && npm run css && npm run css:pages",
    "stylelint": "npx stylelint \"**/*.css\"",
    "eleventy": "npx @11ty/eleventy",
    "eleventy:watch": "npx @11ty/eleventy --watch",
    "js": "esbuild src/core/app.ts --bundle --minify --outfile=public/dist/main/app.js",
    "js:watch": "esbuild src/core/app.ts --bundle --minify --watch --outfile=public/dist/main/app.js",
    "css": "esbuild src/styles/main/main.css --bundle --minify --external:/assets/* --outfile=public/dist/main/styles.css",
    "css:watch": "esbuild src/styles/main/main.css --bundle --minify --watch --external:/assets/* --outfile=public/dist/main/styles.css",
    "css:pages": "esbuild src/styles/data/main.css --bundle --minify --outfile=public/dist/pages.css",
    "css:pages:watch": "esbuild src/styles/data/main.css --bundle --minify --watch  --outfile=public/dist/pages.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Timmy1236/Website.git"
  },
  "keywords": [
    "website",
    "web"
  ],
  "author": "Timmy1236 (https://timmy.nekoweb.org/)",
  "licenses": [
    {
      "type": "CC BY-NC-SA 4.0",
      "url": "https://github.com/Timmy1236/Website/blob/main/LICENSE"
    }
  ],
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Timmy1236/Website/issues"
  },
  "homepage": "https://github.com/Timmy1236/Website#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@types/mithril": "^2.2.8",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "stylelint": "^17.9.1",
    "stylelint-config-standard": "^40.0.0"
  },
  "dependencies": {
    "mithril": "^2.3.8"
  }
}