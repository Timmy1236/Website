---
permalink: en/rss/changelog.xml
eleventyExcludeFromCollections: true
---

<rss version="2.0">
<script src="https://www.rss.style/js/rss-style.js" xmlns="http://www.w3.org/1999/xhtml"></script>
<channel>
  <title>Timmy Changelog - English</title>
  <link>https://timmy.nekoweb.org/content/changelog/en/</link>
  <description>All changelog posts exclusively in English</description>
  <language>en-us</language>

  {% for post in collections.changelog_en %}
  <item>
    <title>{{ post.data.title }}</title>
    <link>https://timmy.nekoweb.org/content{{ post.url }}</link>
    <guid>https://timmy.nekoweb.org/content{{ post.url }}</guid>
    <pubDate>{{ post.date | rssDate }}</pubDate>
    <description>{{ post.data.description }}</description>
  </item>
  {% endfor %}
</channel>
</rss>
